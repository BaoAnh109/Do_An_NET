<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options">
    <!-- =========================================================
         THEME / CONSTANTS
         ========================================================= -->
    <Thickness x:Key="Space.Outer">18</Thickness>
    <Thickness x:Key="Space.Section">16</Thickness>
    <Thickness x:Key="Space.Control">0,0,0,12</Thickness>

    <CornerRadius x:Key="Radius.Small">8</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">10</CornerRadius>
    <CornerRadius x:Key="Radius.Large">16</CornerRadius>
    <CornerRadius x:Key="Radius.XLarge">18</CornerRadius>

    <sys:Double x:Key="Font.Title">28</sys:Double>
    <sys:Double x:Key="Font.Section">18</sys:Double>
    <sys:Double x:Key="Font.Normal">14</sys:Double>
    <sys:Double x:Key="Font.Small">12</sys:Double>

    <!-- =========================================================
         COLORS
         ========================================================= -->
    <Color x:Key="Color.Primary">#7EC8E3</Color>
    <Color x:Key="Color.PrimaryDark">#4FA7C9</Color>
    <Color x:Key="Color.PrimaryLight">#EAF8FD</Color>

    <Color x:Key="Color.WindowBackground">#F6FCFE</Color>
    <Color x:Key="Color.Sidebar">#DDF4FB</Color>
    <Color x:Key="Color.Card">#FFFFFF</Color>

    <Color x:Key="Color.BorderSoft">#C9E8F3</Color>
    <Color x:Key="Color.BorderStrong">#97D1E5</Color>

    <Color x:Key="Color.TextPrimary">#21495C</Color>
    <Color x:Key="Color.TextSecondary">#5B7C8C</Color>
    <Color x:Key="Color.TextWhite">#FFFFFF</Color>

    <Color x:Key="Color.Success">#A8E6CF</Color>
    <Color x:Key="Color.Warning">#FFF7E8</Color>
    <Color x:Key="Color.Danger">#F56C6C</Color>
    <Color x:Key="Color.Info">#D9F3FF</Color>

    <Color x:Key="Color.Hover">#C9ECF8</Color>
    <Color x:Key="Color.Selected">#B8E4F4</Color>
    <Color x:Key="Color.SidebarCard">#F1FBFF</Color>
    <Color x:Key="Color.DangerSoft">#FDEBEC</Color>
    <Color x:Key="Color.DataGridRow">#FFFFFF</Color>
    <Color x:Key="Color.DataGridAlternateRow">#F8FDFF</Color>
    <Color x:Key="Color.DataGridRowBorder">#EDF7FB</Color>
    <Color x:Key="Color.ChartCardBackground">#D9EEF6</Color>
    <Color x:Key="Color.ChartCardBorder">#C6E3ED</Color>
    <Color x:Key="Color.ChartTitle">#2E5565</Color>
    <Color x:Key="Color.ChartAccentDot">#FF5B5B</Color>
    <Color x:Key="Color.ChartGridLine">#BFDCE6</Color>
    <Color x:Key="Color.ChartGridBaseLine">#94B9C7</Color>
    <Color x:Key="Color.ChartArea">#558DBFD1</Color>
    <Color x:Key="Color.ChartLine">#5F9FB7</Color>

    <!-- =========================================================
         BRUSHES
         ========================================================= -->
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Primary" Color="{StaticResource Color.Primary}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.PrimaryDark" Color="{StaticResource Color.PrimaryDark}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.PrimaryLight" Color="{StaticResource Color.PrimaryLight}"/>

    <SolidColorBrush po:Freeze="False" x:Key="Brush.WindowBackground" Color="{StaticResource Color.WindowBackground}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Sidebar" Color="{StaticResource Color.Sidebar}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Card" Color="{StaticResource Color.Card}"/>

    <SolidColorBrush po:Freeze="False" x:Key="Brush.BorderSoft" Color="{StaticResource Color.BorderSoft}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.BorderStrong" Color="{StaticResource Color.BorderStrong}"/>

    <SolidColorBrush po:Freeze="False" x:Key="Brush.TextPrimary" Color="{StaticResource Color.TextPrimary}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.TextSecondary" Color="{StaticResource Color.TextSecondary}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.TextWhite" Color="{StaticResource Color.TextWhite}"/>

    <SolidColorBrush po:Freeze="False" x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Warning" Color="{StaticResource Color.Warning}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Info" Color="{StaticResource Color.Info}"/>

    <SolidColorBrush po:Freeze="False" x:Key="Brush.Hover" Color="{StaticResource Color.Hover}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.Selected" Color="{StaticResource Color.Selected}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.SidebarCard" Color="{StaticResource Color.SidebarCard}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.DangerSoft" Color="{StaticResource Color.DangerSoft}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.DataGridRow" Color="{StaticResource Color.DataGridRow}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.DataGridAlternateRow" Color="{StaticResource Color.DataGridAlternateRow}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.DataGridRowBorder" Color="{StaticResource Color.DataGridRowBorder}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartCardBackground" Color="{StaticResource Color.ChartCardBackground}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartCardBorder" Color="{StaticResource Color.ChartCardBorder}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartTitle" Color="{StaticResource Color.ChartTitle}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartAccentDot" Color="{StaticResource Color.ChartAccentDot}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartGridLine" Color="{StaticResource Color.ChartGridLine}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartGridBaseLine" Color="{StaticResource Color.ChartGridBaseLine}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartArea" Color="{StaticResource Color.ChartArea}"/>
    <SolidColorBrush po:Freeze="False" x:Key="Brush.ChartLine" Color="{StaticResource Color.ChartLine}"/>

    <!-- =========================================================
         EFFECTS
         ========================================================= -->
    <DropShadowEffect x:Key="CardShadowEffect"
                      BlurRadius="12"
                      ShadowDepth="2"
                      Opacity="0.15"
                      Color="#7AAFC3"/>

    <!-- =========================================================
         TEXT STYLES
         ========================================================= -->
    <Style x:Key="TitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Title}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.PrimaryDark}"/>
    </Style>

    <Style x:Key="SectionTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Section}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

    <Style x:Key="LabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
        <Setter Property="Margin" Value="0,0,0,6"/>
    </Style>

    <Style x:Key="BodyTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

    <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource Font.Small}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}"/>
    </Style>

    <!-- =========================================================
         BORDER / CARD STYLES
         ========================================================= -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.XLarge}"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="Effect" Value="{StaticResource CardShadowEffect}"/>
    </Style>

    <Style x:Key="HighlightCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
    </Style>

    <Style x:Key="SidebarCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.SidebarCard}"/>
    </Style>

    <!-- =========================================================
         BUTTON STYLES
         ========================================================= -->
    <Style x:Key="BaseButtonStyle" TargetType="Button">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Medium}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Selected}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextWhite}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.PrimaryDark}"/>
    </Style>

    <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.Success}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderStrong}"/>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource Brush.DangerSoft}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.Danger}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.Danger}"/>
    </Style>

    <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
        <Setter Property="Height" Value="42"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Margin" Value="0,6,0,0"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Selected}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         TEXTBOX STYLE
         ========================================================= -->
    <Style x:Key="AppTextBoxStyle" TargetType="TextBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Small}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource Brush.PrimaryDark}"/>
                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.65"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         PASSWORD BOX STYLE
         ========================================================= -->
    <Style x:Key="AppPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
    </Style>

    <!-- =========================================================
         COMBOBOX STYLE
         ========================================================= -->
    <Style x:Key="AppComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
    </Style>

    <!-- =========================================================
         DATEPICKER STYLE
         ========================================================= -->
    <Style x:Key="AppDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Height" Value="38"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
    </Style>

    <!-- =========================================================
         CHECKBOX / RADIOBUTTON
         ========================================================= -->
    <Style x:Key="AppCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Margin" Value="0,0,12,8"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

    <Style x:Key="AppRadioButtonStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="0,0,12,8"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

    <!-- =========================================================
         LISTBOX STYLE
         ========================================================= -->
    <Style x:Key="AppListBoxStyle" TargetType="ListBox">
        <Setter Property="Margin" Value="0,0,0,12"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

    <!-- =========================================================
         DATAGRID STYLE
         ========================================================= -->
    <Style x:Key="AppDataGridStyle" TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="RowBackground" Value="{DynamicResource Brush.DataGridRow}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource Brush.DataGridAlternateRow}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Card}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,12"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Height" Value="42"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="Background" Value="{DynamicResource Brush.PrimaryLight}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Height" Value="38"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.DataGridRowBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Hover}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource Brush.Selected}"/>
                <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================
         EXPANDER / MENU STYLE
         ========================================================= -->
    <Style x:Key="SidebarExpanderStyle" TargetType="Expander">
        <Setter Property="Margin" Value="0,10,0,0"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="{StaticResource Font.Normal}"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- =========================================================
         STATUS BADGE STYLE
         ========================================================= -->
    <Style x:Key="StatusBadgeBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="10,4"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Background" Value="{DynamicResource Brush.Info}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSoft}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <!-- =========================================================
         WINDOW / USERCONTROL DEFAULTS
         ========================================================= -->
    <Style TargetType="UserControl">
        <Setter Property="Background" Value="{DynamicResource Brush.WindowBackground}"/>
    </Style>

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource Brush.WindowBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}"/>
    </Style>

</ResourceDictionary>



